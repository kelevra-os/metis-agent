# Metis Agent — Environment Variables
# Copy this to ~/.hermes/profiles/metis/.env and fill in your values.
#
#   cp .env.template .env && $EDITOR .env

# Discord bot token for the Metis gateway
# Create one at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=***

# Path to your local Obsidian vault (for note-taking)
# Default: ~/Documents/Obsidian Vault
# Metis creates notes here and syncs them via git.
# Example: /home/you/Documents/Obsidian Vault
OBSIDIAN_VAULT_PATH=

# Git remote for syncing the Obsidian vault
# Required for git push/pull. Leave empty for local-only mode.
# Example: git@github.com:username/obsidian-vault.git
OBSIDIAN_REPO_URL=

# Optional: Wormhole API key for file intake
# Get one at https://wormhole.app/api
WORMHOLE_API_KEY=
