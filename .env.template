# Metis Agent — Environment Variables
# Copy this to .env and fill in your values.

# Discord bot token for the Metis gateway (required for Discord interaction)
DISCORD_BOT_TOKEN=

# Absolute path to your local Obsidian vault (e.g. /home/user/obsidian)
OBSIDIAN_VAULT_PATH=

# Git remote URL for your Obsidian vault (for push/pull sync)
OBSIDIAN_REPO_URL=

# Wormhole API key for cross-device file transfer (optional)
WORMHOLE_API_KEY=
